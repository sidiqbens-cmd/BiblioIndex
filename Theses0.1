<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>Theses 0.1</title>
    <style>
        body { font-family: 'Times New Roman', serif; background: #eceef1; margin: 0; }
        .fixed-header { position: fixed; top: 0; left: 0; right: 0; background: #2c3e50; z-index: 1000; }
        .input-table { width: 100%; background: #cfcfcf; border-spacing: 2px; padding: 5px; }
        input { width: 100%; height: 26px; border: 1px solid #999; box-sizing: border-box; }
        .btn { padding: 5px 10px; cursor: pointer; border: none; border-radius: 3px; color: #fff; font-weight: bold; }
    </style>
</head>
<body>

<div class="fixed-header">
    <table class="input-table">
        <tr>
            <td>القسم<input type="text" id="dept" list="list_dept" class="in" onfocus="updateLists()">
                <datalist id="list_dept"></datalist>
            </td>
            <td>الكلية<input type="text" id="faculty" list="list_faculty" class="in" onfocus="updateLists()">
                <datalist id="list_faculty"></datalist>
            </td>
            <td>الجامعة<input type="text" id="uni" list="list_uni" class="in" onfocus="updateLists()">
                <datalist id="list_uni"></datalist>
            </td>
        </tr>
    </table>
    <div style="text-align:center; padding:10px;">
        <button class="btn" style="background:#27ae60" onclick="save()">حفظ السجل</button>
    </div>
</div>

<script>
let recs = JSON.parse(localStorage.getItem('THESES_DATA')) || [];

// الدالة الأهم: تحديث القوائم
function updateLists() {
    ['dept', 'faculty', 'uni'].forEach(f => {
        let list = document.getElementById('list_' + f);
        let vals = [...new Set(recs.map(r => r[f]).filter(v => v))];
        list.innerHTML = vals.map(v => `<option value="${v}">`).join('');
    });
}

function save() {
    let d = {}; 
    document.querySelectorAll('.in').forEach(i => d[i.id] = i.value.trim());
    recs.push(d);
    localStorage.setItem('THESES_DATA', JSON.stringify(recs));
    updateLists(); // تحديث القوائم بعد الحفظ
    alert("تم الحفظ");
}

// التحديث عند فتح الصفحة
window.onload = updateLists;
</script>
</body>
</html>
